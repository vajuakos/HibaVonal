@namespace HibaVonal.Client.Dialogs.Management

<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h5" Class="mb-2">@Ticket.Title</MudText>

        <MudStack Row="true" Spacing="2" Class="mb-3">
            <MudChip T="string" Icon="@Icons.Material.Filled.MeetingRoom" Size="Size.Small">
                @Ticket.RoomNumber. szoba
            </MudChip>

            <MudChip T="string" Icon="@Icons.Material.Filled.Person" Size="Size.Small">
                @(Ticket.CreatedByEmail ?? "Ismeretlen bejelentő")
            </MudChip>
        </MudStack>

        <MudPaper Class="pa-4" Elevation="0" Style="background: rgba(0,0,0,0.03);">
            <MudText Typo="Typo.body1">
                @(string.IsNullOrWhiteSpace(Ticket.Description) ? "Nincs megadott leírás." : Ticket.Description)
            </MudText>
        </MudPaper>
    </DialogContent>

    <DialogActions>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Close">
            Bezárás
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter] IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter] public TicketDTO Ticket { get; set; } = default!;

    private void Close()
    {
        MudDialog.Close();
    }
}