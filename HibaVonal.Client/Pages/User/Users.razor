@page "/users"
@using System.Linq
@using HibaVonal.Shared.DTO
@inject HttpClient Http

<MudText Typo="Typo.h4" Class="mb-4">Felhasználók kezelése</MudText>
@if (users == null)
{
    <MudProgressCircular Color="Color.Primary" Indeterminate="true"/>
}else if (!users.Any())
{
    <MudAlert Severity="Severity.Info">Nincsenek regisztrált felhasználók.</MudAlert>

}
else{
<MudTable Items="@users" Hover="true" CanCancelEdit="true" RowEditPreview="BackupItem" RowEditCancel="ResetItemToOriginalValues" RowEditCommit="ItemHasBeenCommitted" ApplyButtonPosition="TableApplyButtonPosition.End" EditButtonPosition="TableEditButtonPosition.End" EditTrigger="TableEditTrigger.RowClick">
    <HeaderContent>
        <MudTh>Név (Azonosító)</MudTh>
        <MudTh>Email</MudTh>
        <MudTh>Szerepkör</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Név">@context.FullName</MudTd>
        <MudTd DataLabel="Email">@context.Email</MudTd>
        <MudTd DataLabel="Szerepkör">@context.Role</MudTd>
    </RowTemplate>
    <RowEditingTemplate>
        <MudTd DataLabel="Név">
            <MudTextField @bind-Value="@context.FullName" Required />
        </MudTd>
        <MudTd DataLabel="Email">
            <MudTextField @bind-Value="@context.Email" Required />
        </MudTd>
        <MudTd DataLabel="Szerepkör">
            <MudSelect @bind-Value="@context.Role" T="string" Label="Szerepkör" Variant="Variant.Outlined">
                <MudSelectItem Value="@("Admin")" />
                <MudSelectItem Value="@("User")" />
            </MudSelect>
        </MudTd>
    </RowEditingTemplate>
</MudTable>
}
@code {
    private List<UserDTO>? users;
    private UserDTO elementBeforeEdit;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            users = await Http.GetFromJsonAsync<List<UserDTO>>("api/auth/users");
        }
        catch (Exception ex)
        {
            Console.WriteLine("Hiba: " + ex.Message);
            users = new List<UserDTO>();
        }
    }
  
    private void BackupItem(object element)
    {
        var user = (UserDTO)element;
        elementBeforeEdit = new UserDTO
        {
            Id = user.Id,
            FullName = user.FullName,
            Email = user.Email,
            Role = user.Role
        };
    }

   
    private void ResetItemToOriginalValues(object element)
    {
        var user = (UserDTO)element;
        user.FullName = elementBeforeEdit.FullName;
        user.Email = elementBeforeEdit.Email;
        user.Role = elementBeforeEdit.Role;
    }

    private void ItemHasBeenCommitted(object element)
    {
        var editedUser = (UserDTO)element;
        _ = Http.PutAsJsonAsync($"api/auth/users/{editedUser.Id}", editedUser);
    }
}

