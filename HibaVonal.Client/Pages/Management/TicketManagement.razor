@page "/management/tickets"
@attribute [Authorize(Roles = $"{UserRoles.MaintenanceManager},{UserRoles.DEV}")]

<PageTitle>Menedzsment</PageTitle>

<MudContainer MaxWidth="MaxWidth.False" Class="pa-6">
    <MudPaper Elevation="6"
              Class="pa-6 mx-auto"
              Style="max-width: 1450px; background: rgba(255,255,255,0.95); color: #1f2937;">

        <MudStack Spacing="3">
            <MudText Typo="Typo.h4" Style="font-weight:700;">
                Karbantartási vezető - Ticketek
            </MudText>

            <MudText Typo="Typo.body1" Style="color:#4b5563;">
                Itt tudod a hibajegyek státuszát módosítani, illetve karbantartóhoz rendelni őket.
            </MudText>

            <MudDivider />

            <MudStack Row="true" AlignItems="AlignItems.Center" Justify="Justify.SpaceBetween" Class="mb-2">
                <MudSwitch T="bool"
                           Value="_showCompleted"
                           ValueChanged="OnShowCompletedChanged"
                           Color="Color.Primary"
                           Label="@(_showCompleted ? "Elvégzett hibajegyek" : "Folyamatban lévő hibajegyek")" />

                <MudText Typo="Typo.body2" Style="color:#6b7280;">
                    Aktuális nézet:
                    <strong>@(_showCompleted ? "Elvégzett hibajegyek" : "Nyitott / folyamatban lévő hibajegyek")</strong>
                </MudText>
            </MudStack>

            @if (!string.IsNullOrWhiteSpace(_message))
            {
                <MudAlert Severity="@_messageSeverity" Variant="Variant.Filled" Dense="true">
                    @_message
                </MudAlert>
            }

            @if (_isLoading)
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                    <MudText Class="mt-4">Adatok betöltése...</MudText>
                </MudStack>
            }
            else if (_tickets == null || !_tickets.Any())
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    Nincs megjeleníthető ticket ebben a nézetben.
                </MudAlert>
            }
            else
            {
                <MudTable Items="_tickets"
                          Hover="true"
                          Dense="true"
                          Striped="true"
                          Bordered="true"
                          Breakpoint="Breakpoint.Md">

                    <HeaderContent>
                        <MudTh>Id</MudTh>
                        <MudTh>Cím</MudTh>
                        <MudTh>Szoba</MudTh>
                        <MudTh>Állapot</MudTh>
                        <MudTh>Létrehozó</MudTh>
                        <MudTh>Karbantartó</MudTh>
                        <MudTh>Műveletek</MudTh>
                    </HeaderContent>

                    <RowTemplate Context="ticket">
                        <MudTd DataLabel="Id">@ticket.Id</MudTd>

                        <MudTd DataLabel="Cím">@ticket.Title</MudTd>

                        <MudTd DataLabel="Szoba">@ticket.RoomNumber</MudTd>

                        <MudTd DataLabel="Állapot" Style="min-width: 180px;">
                            <MudSelect T="TicketStatus"
                                       @bind-Value="ticket.Status"
                                       Dense="true"
                                       Variant="Variant.Outlined">
                                @foreach (var status in Enum.GetValues<TicketStatus>())
                                {
                                    <MudSelectItem T="TicketStatus" Value="@status">
                                        @TicketStatusExtensions.ToDisplayString(status)
                                    </MudSelectItem>
                                }
                            </MudSelect>
                        </MudTd>

                        <MudTd DataLabel="Létrehozó">@ticket.CreatedByEmail</MudTd>

                        <MudTd DataLabel="Karbantartó" Style="min-width: 260px;">
                            <MudTooltip Text="@(ticket.Status == TicketStatus.Resolved ? "Lezárt állapotban a hozzárendelés nem módosítható." : "")"
                                        Placement="Placement.Top">
                                <div style="cursor: @(ticket.Status == TicketStatus.Resolved ? "not-allowed" : "default")">
                                    <MudSelect T="int?"
                                               @bind-Value="ticket.AssignedToId"
                                               Dense="true"
                                               Variant="Variant.Outlined"
                                               Disabled="@(_showCompleted)"
                                               Clearable="true">
                                        @foreach (var staff in _maintenanceStaffUsers)
                                        {
                                            <MudSelectItem T="int?" Value="@((int?)staff.Id)">
                                                @staff.Email
                                            </MudSelectItem>
                                        }
                                    </MudSelect>
                                </div>
                            </MudTooltip>

                            <MudStack Row="false" Spacing="0" Class="mt-1">
                                <MudText Typo="Typo.caption" Style="color:#6b7280;">
                                    Jelenleg: @(ticket.AssignedToEmail ?? "Nincs hozzárendelve")
                                </MudText>
                            </MudStack>
                        </MudTd>

                        <MudTd DataLabel="Műveletek" Style="min-width: 560px;">
                            <MudStack Row="true" Spacing="2" Wrap="Wrap.Wrap">
                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Primary"
                                           Size="Size.Small"
                                           Style="min-width: 120px;"
                                           OnClick="@(() => SaveStatus(ticket))">
                                    Státusz mentése
                                </MudButton>

                                <MudButton Variant="Variant.Filled"
                                           Color="Color.Secondary"
                                           Size="Size.Small"
                                           Style="min-width: 140px;"
                                           Disabled="@(!ticket.AssignedToId.HasValue || ticket.Status == TicketStatus.Resolved)"
                                           OnClick="@(() => SaveAssignment(ticket))">
                                    Hozzárendelés mentése
                                </MudButton>

                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Info"
                                           Size="Size.Small"
                                           Style="min-width: 130px;"
                                           OnClick="@(() => NavigationManager.NavigateTo($"/infrastructure/add-equipment-request?ticketId={ticket.Id}"))">
                                    Eszközigény
                                </MudButton>

                                <MudButton Variant="Variant.Outlined"
                                           Color="Color.Default"
                                           Size="Size.Small"
                                           Style="min-width: 100px;"
                                           OnClick="@(() => ShowDescription(ticket))">
                                    Leírás
                                </MudButton>
                            </MudStack>
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    [Inject] IManagementService ManagerService { get; set; } = default!;
    [Inject] NavigationManager NavigationManager { get; set; } = default!;
    [Inject] IDialogService DialogService { get; set; } = default!;

    private List<TicketDTO>? _tickets;
    private List<UserListItemDTO> _maintenanceStaffUsers = new();
    private string? _message;
    private Severity _messageSeverity = Severity.Info;
    private bool _isLoading = true;
    private bool _showCompleted = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadPageData(clearMessage: true);
    }

    private async Task LoadPageData(bool clearMessage = false)
    {
        _isLoading = true;

        if (clearMessage)
        {
            _message = null;
        }

        var ticketResult = await ManagerService.GetTicketsAsync(_showCompleted);
        _tickets = ticketResult.Data ?? new List<TicketDTO>();

        if (!ticketResult.IsSuccess)
        {
            _message = ticketResult.Message;
            _messageSeverity = Severity.Error;
        }

        var staffResult = await ManagerService.GetMaintenanceStaffUsersAsync();
        _maintenanceStaffUsers = staffResult.Data ?? new List<UserListItemDTO>();

        if (!staffResult.IsSuccess)
        {
            _message = staffResult.Message;
            _messageSeverity = Severity.Error;
        }

        _isLoading = false;
    }

    private async Task OnShowCompletedChanged(bool value)
    {
        _showCompleted = value;
        await LoadPageData(clearMessage: true);
    }

    private async Task SaveStatus(TicketDTO ticket)
    {
        var result = await ManagerService.UpdateTicketStatusAsync(ticket.Id, ticket.Status);

        _message = result.Message;
        _messageSeverity = result.IsSuccess ? Severity.Success : Severity.Error;

        if (result.IsSuccess)
        {
            await LoadPageData();
        }
    }

    private async Task SaveAssignment(TicketDTO ticket)
    {
        if (!ticket.AssignedToId.HasValue)
        {
            _message = "Először válassz ki egy karbantartót.";
            _messageSeverity = Severity.Warning;
            return;
        }

        var result = await ManagerService.AssignTicketAsync(ticket.Id, ticket.AssignedToId.Value);

        _message = result.Message;
        _messageSeverity = result.IsSuccess ? Severity.Success : Severity.Error;

        if (result.IsSuccess)
        {
            await LoadPageData();
        }
    }

    private async Task ShowDescription(TicketDTO ticket)
    {
        var parameters = new DialogParameters<TicketDescriptionDialog>
        {
            { x => x.Ticket, ticket }
        };

        var options = new DialogOptions
        {
            CloseButton = true,
            MaxWidth = MaxWidth.Medium,
            FullWidth = true
        };

        await DialogService.ShowAsync<TicketDescriptionDialog>(
            "Hibajegy leírása",
            parameters,
            options);
    }
}