

@code {

}
@page "/admin/equipment"
@using HibaVonal.Shared.DTO
@using HibaVonal.Client.Services.Administrator
@inject IAdministratorService AdminService

<div class="container-fluid">
    <h4 class="mb-4">Eszközök és Hibatípusok Kezelése</h4>

    @if (equipments == null)
    {
        <div class="d-flex justify-content-center">
            <div class="spinner-border text-primary" role="status">
                <span class="visually-hidden">Betöltés...</span>
            </div>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover border">
                <thead class="table-dark">
                    <tr>
                        <th>Eszköz neve</th>
                        <th>Típus / Hiba kategória</th>
                        <th>Helyiség száma</th>
                        <th class="text-center">Műveletek</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in equipments)
                    {
                        <tr>
                            <td>@item.Name</td>
                            <td>@item.Type</td>
                            <td>@item.RoomNumber</td>
                            <td class="text-center">
                                <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteItem(item.Id)">
                                    <i class="oi oi-trash"></i> Eltávolítás
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="card shadow-sm mt-5">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Új eszköz vagy felszerelés hozzáadása</h5>
            </div>
            <div class="card-body">
                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="form-label">Eszköz neve</label>
                        <input @bind="newEquipment.Name" class="form-control" placeholder="Pl: Csaptelep" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Típus</label>
                        <input @bind="newEquipment.Type" class="form-control" placeholder="Pl: Vizesblokk" />
                    </div>
                    <div class="col-md-3">
                        <label class="form-label">Helyiség</label>
                        <input @bind="newEquipment.RoomNumber" class="form-control" placeholder="Pl: 204. szoba" />
                    </div>
                    <div class="col-md-2 d-flex align-items-end">
                        <button class="btn btn-success w-100" @onclick="SaveEquipment">
                            Hozzáadás
                        </button>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private List<EquipmentDTO> equipments;
    private EquipmentDTO newEquipment = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        // A te saját AdministratorService-edet hívja meg
        equipments = await AdminService.GetEquipmentsAsync();
    }

    private async Task SaveEquipment()
    {
        if (!string.IsNullOrWhiteSpace(newEquipment.Name))
        {
            var success = await AdminService.AddEquipmentAsync(newEquipment);
            if (success)
            {
                newEquipment = new(); // Mezők ürítése
                await LoadData();     // Lista frissítése
            }
        }
    }

    private async Task DeleteItem(int id)
    {
        var success = await AdminService.RemoveEquipmentAsync(id);
        if (success)
        {
            await LoadData();
        }
    }
}