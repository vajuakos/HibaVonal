@page "/admin/equipment"
@attribute [Authorize(Roles = $"{UserRoles.Admin},{UserRoles.DEV}")]
@using MudBlazor
@inject IAdministratorService AdminService
@inject ISnackbar Snackbar

<MudContainer MaxWidth="MaxWidth.False" Class="pa-6">
    <MudPaper Elevation="6"
              Class="pa-6 mx-auto"
              Style="max-width: 1450px; background: rgba(255,255,255,0.95); color: #1f2937;">

        <MudStack Spacing="3">
            <MudText Typo="Typo.h4" Style="font-weight:700;">
                Eszközök és hibatípusok kezelése
            </MudText>

            <MudText Typo="Typo.body1" Style="color:#4b5563;">
                Itt tudsz új eszközt vagy felszerelést hozzáadni, illetve meglévő elemeket törölni.
            </MudText>

            <MudDivider />

            @if (_isLoading)
            {
                <MudStack AlignItems="AlignItems.Center" Class="pa-8">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                    <MudText Class="mt-4">Adatok betöltése...</MudText>
                </MudStack>
            }
            else
            {
                <MudTable Items="equipments"
                          Hover="true"
                          Dense="true"
                          Striped="true"
                          Bordered="true"
                          Breakpoint="Breakpoint.Md">

                    <HeaderContent>
                        <MudTh>Eszköz neve</MudTh>
                        <MudTh>Típus / Hiba kategória</MudTh>
                        <MudTh>Helyiség száma</MudTh>
                        <MudTh>Műveletek</MudTh>
                    </HeaderContent>

                    <RowTemplate Context="item">
                        <MudTd DataLabel="Eszköz neve">@item.Name</MudTd>
                        <MudTd DataLabel="Típus / Hiba kategória">@item.Type</MudTd>
                        <MudTd DataLabel="Helyiség száma">@item.RoomNumber</MudTd>
                        <MudTd DataLabel="Műveletek">
                            <MudButton Variant="Variant.Filled"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       StartIcon="@Icons.Material.Filled.Delete"
                                       OnClick="@(() => DeleteItem(item.Id))">
                                Eltávolítás
                            </MudButton>
                        </MudTd>
                    </RowTemplate>

                    <NoRecordsContent>
                        <MudText>Nincs még rögzített eszköz.</MudText>
                    </NoRecordsContent>
                </MudTable>

                <MudPaper Elevation="2" Class="pa-6 mt-6" Style="background:#f8fafc;">
                    <MudText Typo="Typo.h5" Class="mb-4" Style="font-weight:600;">
                        Új eszköz vagy felszerelés hozzáadása
                    </MudText>

                    <MudGrid Spacing="3">
                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="newEquipment.Name"
                                          Label="Eszköz neve"
                                          Placeholder="Pl.: Csaptelep"
                                          Variant="Variant.Outlined"
                                          Dense="true"
                                          FullWidth="true" />
                        </MudItem>

                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="newEquipment.Type"
                                          Label="Típus"
                                          Placeholder="Pl.: Vizesblokk"
                                          Variant="Variant.Outlined"
                                          Dense="true"
                                          FullWidth="true" />
                        </MudItem>

                        <MudItem xs="12" md="4">
                            <MudTextField @bind-Value="newEquipment.RoomNumber"
                                          Label="Helyiség"
                                          Placeholder="Pl.: 204. szoba"
                                          Variant="Variant.Outlined"
                                          Dense="true"
                                          FullWidth="true" />
                        </MudItem>
                    </MudGrid>

                    <MudStack Row="true" Justify="Justify.FlexEnd" Class="mt-4">
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Success"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="SaveEquipment">
                            Hozzáadás
                        </MudButton>
                    </MudStack>
                </MudPaper>
            }
        </MudStack>
    </MudPaper>
</MudContainer>

@code {
    private List<EquipmentDTO> equipments = new();
    private EquipmentDTO newEquipment = new();
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        _isLoading = true;
        equipments = await AdminService.GetEquipmentsAsync();
        _isLoading = false;
    }

    private async Task SaveEquipment()
    {
        if (string.IsNullOrWhiteSpace(newEquipment.Name))
        {
            Snackbar.Add("Az eszköz neve kötelező.", Severity.Warning);
            return;
        }

        var success = await AdminService.AddEquipmentAsync(newEquipment);

        if (success)
        {
            Snackbar.Add("Eszköz sikeresen hozzáadva.", Severity.Success);
            newEquipment = new EquipmentDTO();
            await LoadData();
        }
        else
        {
            Snackbar.Add("Az eszköz hozzáadása sikertelen volt.", Severity.Error);
        }
    }

    private async Task DeleteItem(int id)
    {
        var success = await AdminService.RemoveEquipmentAsync(id);

        if (success)
        {
            Snackbar.Add("Eszköz sikeresen eltávolítva.", Severity.Success);
            await LoadData();
        }
        else
        {
            Snackbar.Add("Az eszköz törlése sikertelen volt.", Severity.Error);
        }
    }
}