@page "/maintenance/tickets"
@attribute [Authorize(Roles = $"{UserRoles.MaintenanceStaff},{UserRoles.DEV}")]

<PageTitle>Karbantartói hibajegyek</PageTitle>

<style>
    .glass-card {
        padding: 40px;
        background: rgba(255, 255, 255, 0.2) !important;
        backdrop-filter: blur(10px) saturate(180%);
        -webkit-backdrop-filter: blur(10px) saturate(180%);
        border: 1px solid rgba(255, 255, 255, 0.3) !important;
        box-shadow: 0 8px 32px 0 rgba(0, 0, 0, 0.3);
        border-radius: 10px;
    }

    .blurry {
        backdrop-filter: blur(10px);
    }
</style>

<MudPaper Elevation="2" Class="pa-4 mb-6 rounded-xl border-solid border-2 mud-border-primary"
          Style="background: rgba(255, 255, 255, 0.5); backdrop-filter: blur(10px);">

    <MudStack Row="true" Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Wrap="Wrap.Wrap" Spacing="4">

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="3">
            <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Size="Size.Medium" Class="elevation-2">
                <MudIcon Icon="@Icons.Material.Filled.Engineering" />
            </MudAvatar>
            <div>
                <MudText Typo="Typo.h5" Class="font-weight-bold" Style="line-height: 1.2;">Karbantartói hibajegyek</MudText>
                <MudText Typo="Typo.caption" Class="mud-text-secondary text-uppercase font-weight-bold">Hozzárendelt feladatok</MudText>
            </div>
        </MudStack>

        <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="4" Wrap="Wrap.Wrap">
            <MudPaper Elevation="0" Class="px-4 py-1 rounded-pill d-flex align-center"
                      Style="background: rgba(var(--mud-palette-primary-rgb), 0.05); border: 1px solid rgba(var(--mud-palette-primary-rgb), 0.1);">
                <MudSwitch T="bool"
                           Value="isCompletedTicketsShowing"
                           ValueChanged="OnSwitchChanged"
                           ThumbIcon="@(isCompletedTicketsShowing ? Icons.Material.Filled.DoneAll : Icons.Material.Filled.PendingActions)"
                           Color="@(isCompletedTicketsShowing ? Color.Success : Color.Warning)"
                           Label="@(isCompletedTicketsShowing ? "Lezárt jegyek" : "Folyamatban")"
                           Class="ma-0 font-weight-medium" />
            </MudPaper>
        </MudStack>

    </MudStack>
</MudPaper>

<MudGrid Justify="Justify.Center">
    @if (tickets.Count == 0)
    {
        <MudItem xs="12">
            <div class="d-flex justify-center align-center w-100" style="min-height: 350px;">
                <MudPaper Elevation="0"
                          Class="pa-8 d-flex flex-column align-center justify-center rounded-xl"
                          Style="background: rgba(255, 255, 255, 0.05); backdrop-filter: blur(10px); border: 1px solid rgba(255, 255, 255, 0.15); max-width: 450px; width: 100%;">

                    <MudIcon Icon="@(isCompletedTicketsShowing ? Icons.Material.Outlined.CheckCircleOutline : Icons.Material.Outlined.BuildCircle)"
                             Style="@($"font-size: 5rem; color: {(isCompletedTicketsShowing ? "rgba(76, 175, 80, 0.8)" : "rgba(255, 255, 255, 0.9)")};")"
                             Class="mb-4" />

                    <MudText Typo="Typo.h5" Class="text-center mb-2" Style="color: #ffffff; font-weight: 400; letter-spacing: 0.5px;">
                        @(isCompletedTicketsShowing ? "Nincs lezárt hozzárendelt hibajegy" : "Nincs aktív hozzárendelt hibajegy")
                    </MudText>

                    <MudText Typo="Typo.body1" Class="text-center mb-6" Style="color: rgba(255, 255, 255, 0.7); font-weight: 300;">
                        @(isCompletedTicketsShowing
                            ? "Az elvégzett, hozzád rendelt munkák itt fognak megjelenni."
                            : "Jelenleg nincs hozzád rendelt nyitott vagy folyamatban lévő feladat.")
                    </MudText>
                </MudPaper>
            </div>
        </MudItem>
    }
    else
    {
        @foreach (var ticket in tickets)
        {
            <MudItem xs="12" sm="6" md="4" lg="3">
                <MudCard Elevation="4" Class="rounded-lg mud-width-full"
                         Style="transition: transform 0.2s; cursor: pointer;"
                         onmouseover="this.style.transform='translateY(-4px)'"
                         onmouseout="this.style.transform='translateY(0)'">

                    <MudCardHeader Class="pb-0">
                        <CardHeaderContent>
                            <div class="d-flex justify-space-between align-start">
                                <MudStack Spacing="0">
                                    <MudText Typo="Typo.caption" Color="Color.Primary" Class="fw-bold text-uppercase">
                                        #@ticket.Id • @ticket.CreatedAt.ToString("yyyy.MM.dd")
                                    </MudText>
                                    <MudText Typo="Typo.h6" Class="mud-text-secondary mt-n1" Style="font-weight: 700;">
                                        @ticket.Title
                                    </MudText>
                                </MudStack>

                                <MudChip T="string"
                                         Size="Size.Small"
                                         Variant="Variant.Text"
                                         Color="@GetStatusColor(ticket.Status)"
                                         Class="ml-2">
                                    @GetStatusText(ticket.Status)
                                </MudChip>
                            </div>
                        </CardHeaderContent>
                    </MudCardHeader>

                    <MudCardContent Style="height: 130px; overflow-y: auto;">
                        <MudText Typo="Typo.body2" Color="Color.Default" Class="line-clamp-3">
                            @ticket.Description
                        </MudText>

                        <MudStack Row="true" Spacing="1" Class="mt-2" Wrap="Wrap.Wrap">
                            <MudChip T="string" Icon="@Icons.Material.Filled.MeetingRoom" Size="Size.Small" Class="px-2">
                                @ticket.RoomNumber. szoba
                            </MudChip>

                            @if (!string.IsNullOrWhiteSpace(ticket.CreatedByEmail))
                            {
                                <MudChip T="string" Icon="@Icons.Material.Filled.Person" Size="Size.Small" Class="px-2">
                                    @ticket.CreatedByEmail
                                </MudChip>
                            }
                        </MudStack>
                    </MudCardContent>

                    <MudDivider DividerType="DividerType.Middle" Class="mx-4 my-1" />

                    <MudCardActions Class="d-flex justify-end px-4 pb-3">
                        <MudStack Row="true" Spacing="1" Wrap="Wrap.Wrap">

                            @if (ticket.Status != TicketStatus.Resolved)
                            {
                                <MudButton StartIcon="@Icons.Material.Filled.Inventory"
                                           Size="Size.Small"
                                           Variant="Variant.Text"
                                           Color="Color.Info"
                                           OnClick="@(() => GoToEquipmentRequest(ticket.Id))">
                                    Eszközigény
                                </MudButton>

                                <MudButton StartIcon="@Icons.Material.Filled.DoneAll"
                                           Size="Size.Small"
                                           Variant="Variant.Text"
                                           Color="Color.Success"
                                           OnClick="@(() => ResolveTicket(ticket.Id))">
                                    Lezárás
                                </MudButton>
                            }
                            else
                            {
                                <MudButton StartIcon="@Icons.Material.Filled.Visibility"
                                           Size="Size.Small"
                                           Variant="Variant.Text"
                                           Color="Color.Secondary"
                                           Disabled="true">
                                    Elvégzett
                                </MudButton>
                            }

                        </MudStack>
                    </MudCardActions>
                </MudCard>
            </MudItem>
        }
    }
</MudGrid>

@code {
    [Inject] NavigationManager NavigationManager { get; set; } = default!;
    [Inject] IMaintenanceStaffService MaintenanceStaffService { get; set; } = default!;
    [Inject] ISnackbar Snackbar { get; set; } = default!;

    private List<TicketDTO> tickets = new();
    private bool isCompletedTicketsShowing = false;

    protected override async Task OnInitializedAsync()
    {
        await LoadTickets();
    }

    private async Task LoadTickets()
    {
        var response = await MaintenanceStaffService.GetAssignedTicketsAsync(isCompletedTicketsShowing);

        if (response.IsSuccess && response.Data != null)
        {
            tickets = response.Data;
        }
        else
        {
            Snackbar.Add(response.Message ?? "Nem sikerült betölteni a hibajegyeket.", Severity.Error);
        }
    }

    private async Task OnSwitchChanged(bool newValue)
    {
        isCompletedTicketsShowing = newValue;
        await LoadTickets();
    }

    private void GoToEquipmentRequest(int ticketId)
    {
        NavigationManager.NavigateTo($"/maintenance/equipment-request?ticketId={ticketId}");
    }

    private async Task ResolveTicket(int ticketId)
    {
        var response = await MaintenanceStaffService.ResolveTicketAsync(ticketId);

        if (response.IsSuccess)
        {
            Snackbar.Add(response.Message ?? "A hibajegy lezárva.", Severity.Success);
            await LoadTickets();
        }
        else
        {
            Snackbar.Add(response.Message ?? "A hibajegy lezárása sikertelen.", Severity.Error);
        }
    }

    private static string GetStatusText(TicketStatus status)
    {
        return status switch
        {
            TicketStatus.New => "Új",
            TicketStatus.InProgress => "Folyamatban",
            TicketStatus.Resolved => "Elvégzett",
            _ => status.ToString()
        };
    }

    private static Color GetStatusColor(TicketStatus status)
    {
        return status switch
        {
            TicketStatus.New => Color.Warning,
            TicketStatus.InProgress => Color.Info,
            TicketStatus.Resolved => Color.Success,
            _ => Color.Default
        };
    }
}