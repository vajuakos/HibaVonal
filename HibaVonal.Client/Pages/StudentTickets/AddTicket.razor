@page "/student/add-ticket"

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8 mb-8">

    <MudPaper Elevation="4" Class="pa-8 rounded-xl">

        <MudForm @ref="_addForm">

            <div class="d-flex align-center mb-8">
                <MudAvatar Color="Color.Primary" Variant="Variant.Filled" Class="mr-4" Style="width: 56px; height: 56px;">
                    <MudIcon Icon="@Icons.Material.Filled.HomeRepairService" Size="Size.Large" />
                </MudAvatar>
                <div>
                    <MudText Typo="Typo.h5" Class="font-weight-bold">Új hibabejelentés</MudText>
                    <MudText Typo="Typo.body2" Class="mud-text-secondary">Kérjük, add meg a hiba részleteit a gyors javítás érdekében.</MudText>
                </div>
            </div>

            <MudGrid Spacing="3">
                <MudItem xs="12" md="9">
                    <MudTextField @bind-Value="ticket.Title"
                                  Label="Hiba megnevezése"
                                  Placeholder="pl. Kiégett a villanykörte, Nem folyik a melegvíz..."
                                  Required="true"
                                  RequiredError="Kérlek, adj meg egy rövid címet!"
                                  Variant="Variant.Outlined"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Title"
                                  FullWidth="true" />
                </MudItem>

                <MudItem xs="12" md="3">
                    <MudNumericField @bind-Value="ticket.RoomNumber"
                                     Label="Szoba"
                                     Required="true"
                                     RequiredError="Kötelező!"
                                     Variant="Variant.Outlined"
                                     Min="1"
                                     Max="999"
                                     HideSpinButtons="false"
                                     Adornment="Adornment.Start"
                                     AdornmentIcon="@Icons.Material.Filled.MeetingRoom"
                                     FullWidth="true" />
                </MudItem>

                <MudItem xs="12">
                    <MudTextField T="string"
                                  @bind-Value="ticket.Description"
                                  Label="Részletes leírás"
                                  Placeholder="Írd le pontosan, hol található a hiba és mi a jelenség..."
                                  Required="true"
                                  RequiredError="A leírás megadása kötelező!"
                                  Variant="Variant.Outlined"
                                  Lines="6"
                                  Counter="1000"
                                  MaxLength="1000"
                                  Immediate="true"
                                  Adornment="Adornment.Start"
                                  AdornmentIcon="@Icons.Material.Filled.Description" />
                </MudItem>
            </MudGrid>

            <MudDivider Class="my-6" />

            <MudStack Row="true" Justify="Justify.FlexEnd" Spacing="3">
                <MudButton Variant="Variant.Text"
                           Color="Color.Default"
                           StartIcon="@Icons.Material.Filled.ArrowBack"
                           OnClick="@(() => NavigationManager.NavigateTo("/student/tickets"))"
                           Class="px-6">
                    Mégse
                </MudButton>

                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Send"
                           OnClick="HandleSubmit"
                           Class="px-10 rounded-pill">
                    Hibajegy beküldése
                </MudButton>
            </MudStack>

        </MudForm>

    </MudPaper>
</MudContainer>

@code {
    [Inject] NavigationManager NavigationManager { get; set; } = default!;
    [Inject] IStudentTicketsService StudentTicketsService { get; set; } = default!;
    [Inject] ISnackbar Snackbar { get; set; } = default!;

    MudForm _addForm;
    TicketDTO ticket = new();

    async Task HandleSubmit()
    {
        await _addForm.Validate();

        if (_addForm.IsValid)
        {
            var result = await StudentTicketsService.CreateNewTicketAsync(ticket);
            Snackbar.Add(result.Message, result.IsSuccess ? Severity.Success : Severity.Error);

            NavigationManager.NavigateTo("/student/tickets");
        }
    }
}
